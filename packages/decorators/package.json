    "./createParameterDecorator": {
      "types": "./dist/core/decorators/parameter/index.d.ts",
      "default": "./dist/core/decorators/parameter/index.js"
    },
    "./createPropertyDecorator": {
      "types": "./dist/core/decorators/property/index.d.ts",
      "default": "./dist/core/decorators/property/index.js"
