  "scripts": {
    "clean": "rimraf dist",
    "build": "node scripts/build.mjs",
    "sync-exports": "node scripts/sync-decorators.mjs",
    "test": "jest -c jest.config.ts",
    "lint": "concurrently --prefixColors auto --group --names \"eslint,deps,types,spell,oxlint\" --prefix \"[{name}]\" \"yarn lint:eslint\" \"yarn lint:deps\" \"yarn lint:types\" \"yarn lint:spell\" \"yarn lint:oxlint\"",
    "format": "oxfmt",
    "lint:eslint": "eslint \"src/**/*.ts\" --fix",
    "lint:deps": "npx -y npm-package-json-lint@9.0.0 ./package.json",
    "lint:types": "tsc --noEmit -p tsconfig.json",
    "lint:spell": "npx -y cspell@9.4.0 . --gitignore --quiet",
    "lint:oxlint": "oxlint --disable-nested-config --fix",
    "publish:patch": "npm version patch && npm publish --access public"
  },
  "dependencies": {
    "picocolors": "1.1.1",
    "utility-types": "3.11.0",
    "zod": "3.24.1"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "packageManager": "yarn@4.12.0"
